{
  "name": "juejin-course-homework",
  "version": "1.0.0",
  "private": true,
  "description": "Juejin course page homework built with Webpack + React + TypeScript + Tailwind CSS",
  "scripts": {
    "dev": "webpack serve --mode development --open",
    "build": "webpack --mode production",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write .",
    "prepare": "cd ../../.. && git config core.hooksPath week06/homework/juejin/.husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "./node_modules/.bin/eslint --fix",
      "./node_modules/.bin/prettier --write"
    ],
    "*.{js,cjs,json,md,css,html}": [
      "./node_modules/.bin/prettier --write"
    ]
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@commitlint/cli": "19.8.0",
    "@commitlint/config-conventional": "19.8.0",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@typescript-eslint/eslint-plugin": "8.16.0",
    "@typescript-eslint/parser": "8.16.0",
    "autoprefixer": "10.4.20",
    "css-loader": "7.1.2",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-prettier": "5.2.1",
    "eslint-plugin-react": "7.37.2",
    "eslint-plugin-react-hooks": "5.0.0",
    "html-webpack-plugin": "5.6.3",
    "husky": "9.1.7",
    "lint-staged": "15.2.10",
    "postcss": "8.4.49",
    "postcss-loader": "8.1.1",
    "prettier": "3.3.3",
    "style-loader": "4.0.0",
    "tailwindcss": "3.4.15",
    "ts-loader": "9.5.1",
    "typescript": "5.6.3",
    "webpack": "5.96.1",
    "webpack-cli": "5.1.4",
    "webpack-dev-server": "5.1.0"
  }
}
